            "in": "path",
            "name": "collection",
            "schema": { "type": "string" },
            "required": true
          }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": {
            "description": "200 OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "documents": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": { "_id": { "type": "string" } },
                        "required": ["_id"],
                        "additionalProperties": true
                      }
                    },
                    "operation": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "map" },
                            "jqMappingCommandPerDocument": { "type": "string" }
                          },
                          "required": ["type", "jqMappingCommandPerDocument"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "reject" },
                            "message": { "type": "string" }
                          },
                          "required": ["type", "message"]
                        }
                      ]
                    }
                  },
                  "required": ["documents"]
                }
              }
            }
          }
        }
      },
