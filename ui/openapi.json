              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "documents": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": { "_id": { "type": "string" } },
                        "required": ["_id"],
                        "additionalProperties": true
                      }
                    }
                  },
                  "required": ["name", "documents"]
                }
              }
            }
          }
        }
      }
    },
    "/collections/{collection}": {
      "get": {
        "operationId": "get-collection",
        "description": "Get a single collection by name",
        "parameters": [
          {
            "in": "path",
            "name": "collection",
            "schema": { "type": "string" },
            "required": true
          }
        ],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": {
            "description": "200 OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
