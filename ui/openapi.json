            "required": true
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "responses": {
          "200": {
            "description": "200 OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "document": {
                      "type": "object",
                      "properties": { "_id": { "type": "string" } },
                      "required": ["_id"],
                      "additionalProperties": true
                    },
                    "operation": {
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "map" },
                            "jqMappingCommandPerDocument": { "type": "string" }
                          },
                          "required": ["type", "jqMappingCommandPerDocument"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "reject" },
                            "message": { "type": "string" }
                          },
                          "required": ["type", "message"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "isSubset" }
                          },
                          "required": ["type"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "isSuperset" }
                          },
                          "required": ["type"]
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": { "type": "string", "const": "migrate" },
                            "newSchema": { "type": "object" },
                            "jqMappingCommandPerDocumentFromOldToNewSchema": {
                              "type": "string"
                            }
                          },
                          "required": [
                            "type",
                            "newSchema",
                            "jqMappingCommandPerDocumentFromOldToNewSchema"
                          ]
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        }
      },
