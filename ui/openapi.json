        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object" } } }
        },
        "responses": {
          "200": {
            "description": "200 OK",
            "content": {
              "application/json": {
                "schema": {
                  "anyOf": [
                    { "type": "object", "additionalProperties": true },
                    { "type": "string" }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/collections/{collection}/documents": {
